---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/best-email-marketing-software', label: 'Best Tools' },
  { href: '/email-marketing-tools', label: 'Compare' },
  { href: '/about', label: 'About' },
];
---

<header class="bg-white border-b border-border sticky top-0 z-50">
  <nav class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-primary">
      EmailPlatformGuide
    </a>
    <ul class="flex gap-6 text-sm font-medium">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="text-text-muted hover:text-primary transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
